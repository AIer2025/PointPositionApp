<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <variable name="appStartTime" value="" />

  <targets>
    <!-- 按启动时间命名的详细日志 -->
    <target name="logfile" xsi:type="File"
            fileName="${basedir}/logs/PointPosition_${var:appStartTime}.log"
            layout="${longdate} [${level:uppercase=true}] [${logger:shortName=true}] ${message} ${exception:format=tostring}"
            keepFileOpen="true"
            concurrentWrites="false"
            encoding="utf-8"/>
    <!-- 按日期归档的日志（保留兼容） -->
    <target name="dailylog" xsi:type="File"
            fileName="${basedir}/logs/${shortdate}.log"
            layout="${longdate} [${level:uppercase=true}] [${logger:shortName=true}] ${message} ${exception:format=tostring}"
            archiveEvery="Day" maxArchiveFiles="30"
            encoding="utf-8"/>
    <target name="console" xsi:type="Console"
            layout="${time} [${level:uppercase=true}] ${message}"/>
  </targets>

  <rules>
    <logger name="*" minlevel="Debug" writeTo="logfile,dailylog"/>
    <logger name="*" minlevel="Info" writeTo="console"/>
  </rules>

</nlog>
