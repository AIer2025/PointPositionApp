<Window x:Class="PointPositionApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PointPositionApp.ViewModels"
        xmlns:models="clr-namespace:PointPositionApp.Models"
        Title="点位配置软件 - SmartLabOS" Height="800" Width="1400"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== 顶部工具栏 ========== -->
        <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}" Padding="8,6">
            <DockPanel>
                <TextBlock Text="⚙ 点位配置软件" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                           FontFamily="Microsoft YaHei UI" DockPanel.Dock="Left" Margin="4,0,20,0"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="🔌 连接PLC" Style="{StaticResource AccentButton}"
                            Command="{Binding ConnectPlcCommand}" Margin="2,0"/>
                    <Button Content="⛔ 断开PLC" Style="{StaticResource DangerButton}"
                            Command="{Binding DisconnectPlcCommand}" Margin="2,0"/>
                    <Button Content="🏠 全轴回原点" Style="{StaticResource SuccessButton}"
                            Command="{Binding HomeAllCommand}" Margin="8,0,2,0"/>
                    <Button Content="🔄 刷新数据" Style="{StaticResource DarkButton}"
                            Command="{Binding RefreshTreeCommand}" Margin="2,0"/>
                    <Button Content="⚙ 设置" Style="{StaticResource DarkButton}"
                            Command="{Binding OpenSettingsCommand}" Margin="2,0"/>
                </StackPanel>

                <!-- PLC连接指示 -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="10,0">
                    <Ellipse Width="10" Height="10" Margin="4,0"
                             Fill="{Binding IsPlcConnected, Converter={StaticResource ConnectionStateToBrushConverter}}"/>
                    <TextBlock Text="{Binding IsPlcConnected, Converter={StaticResource ConnectionStateToTextConverter}, ConverterParameter='PLC '}"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ========== 主体区域 ========== -->
        <Grid Grid.Row="1" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="320" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧：树形导航 ===== -->
            <GroupBox Grid.Column="0" Header="📂 项目导航" Style="{StaticResource DarkGroupBox}">
                <TreeView x:Name="tvNavigation" ItemsSource="{Binding TreeNodes}"
                          SelectedItemChanged="TreeView_SelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type models:TreeNodeItem}"
                                                  ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding DisplayName}" Padding="2"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="4" Background="{StaticResource BgLightBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- ===== 中间：点位视图 ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 信息栏 -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="4" Padding="10,6" Margin="4,4,4,2">
                    <DockPanel>
                        <TextBlock Text="{Binding SelectedNodeInfo}" Style="{StaticResource BaseTextStyle}"
                                   FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <TextBlock Text="{Binding SelectedCellInfo}" Style="{StaticResource LabelStyle}"
                                   DockPanel.Dock="Right" HorizontalAlignment="Right"
                                   FontFamily="Consolas" Foreground="{StaticResource AccentBrush}"/>
                    </DockPanel>
                </Border>

                <!-- 点位网格 -->
                <GroupBox Grid.Row="1" Header="📍 点位视图" Style="{StaticResource DarkGroupBox}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="icGrid" ItemsSource="{Binding GridCells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="{Binding GridCols}" Rows="{Binding GridRows}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="cellBorder" Margin="2" CornerRadius="3"
                                            BorderThickness="2" Cursor="Hand"
                                            Background="{Binding HasPoint, Converter={StaticResource HasPointToBrushConverter}}"
                                            BorderBrush="{Binding IsSelected, Converter={StaticResource IsSelectedToBorderConverter}}"
                                            MinWidth="42" MinHeight="36"
                                            MouseLeftButtonDown="GridCell_Click"
                                            MouseRightButtonDown="GridCell_RightClick"
                                            Tag="{Binding}">
                                        <TextBlock Text="{Binding Label}" FontSize="10"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White" FontFamily="Consolas"/>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="💾 保存当前位置" Click="SavePoint_Click"/>
                                                <MenuItem Header="🗑 清除点位" Click="ClearPoint_Click"/>
                                                <MenuItem Header="🎯 跳转到此点" Click="GotoPoint_Click"/>
                                                <Separator/>
                                                <MenuItem Header="📋 复制第1行到所有行" Click="CopyRow_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </GroupBox>

                <!-- 操作按钮 -->
                <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="4" Padding="8,6" Margin="4,2,4,4">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="💾 保存点位" Style="{StaticResource SuccessButton}"
                                Command="{Binding SavePointCommand}" Margin="4,0"/>
                        <Button Content="🗑 清除点位" Style="{StaticResource DangerButton}"
                                Command="{Binding ClearPointCommand}" Margin="4,0"/>
                        <Button Content="🎯 跳转点位" Style="{StaticResource AccentButton}"
                                Command="{Binding GotoPointCommand}" Margin="4,0"/>
                        <Button Content="📋 批量复制(行1→全部)" Style="{StaticResource DarkButton}"
                                Command="{Binding CopyRowCommand}" Margin="4,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" Background="{StaticResource BgLightBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- ===== 右侧：控制面板 ===== -->
            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- 轴控制面板 -->
                    <GroupBox Header="🔧 轴控制" Style="{StaticResource DarkGroupBox}">
                        <ItemsControl ItemsSource="{Binding Axes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgDarkBrush}"
                                            CornerRadius="4" Margin="0,3" Padding="8,6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 行1: 轴名 + 当前位置 + 使能 -->
                                            <DockPanel Grid.Row="0" Margin="0,2">
                                                <TextBlock Text="{Binding Config.AxisName}" Style="{StaticResource AxisNameStyle}"
                                                           DockPanel.Dock="Left" MinWidth="45"/>
                                                <CheckBox Content="使能" Style="{StaticResource DarkCheckBox}"
                                                          IsChecked="{Binding IsEnabled}"
                                                          DockPanel.Dock="Right" Margin="4,0,0,0"
                                                          Checked="AxisEnable_Changed" Unchecked="AxisEnable_Changed"
                                                          Tag="{Binding}"/>
                                                <TextBlock Text="当前:" Style="{StaticResource LabelStyle}" DockPanel.Dock="Left"/>
                                                <TextBox Text="{Binding CurrentPosition, Converter={StaticResource FloatDisplayConverter}, Mode=OneWay}"
                                                         Style="{StaticResource ReadOnlyTextBox}"
                                                         Width="90" DockPanel.Dock="Left" Margin="2,0"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelStyle}" DockPanel.Dock="Left"/>
                                            </DockPanel>

                                            <!-- 行2: 点动 + 速度 -->
                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,3">
                                                <Button Content="◀" Style="{StaticResource SmallButton}" Width="32"
                                                        PreviewMouseLeftButtonDown="JogReverse_Down"
                                                        PreviewMouseLeftButtonUp="JogReverse_Up"
                                                        Tag="{Binding}" ToolTip="点动反向"/>
                                                <Button Content="▶" Style="{StaticResource SmallButton}" Width="32"
                                                        PreviewMouseLeftButtonDown="JogForward_Down"
                                                        PreviewMouseLeftButtonUp="JogForward_Up"
                                                        Tag="{Binding}" ToolTip="点动正向" Margin="2,0,6,0"/>

                                                <TextBlock Text="手动:" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding ManualSpeed, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DarkTextBox}" Width="55"
                                                         LostFocus="ManualSpeed_LostFocus" Tag="{Binding}"/>
                                                <TextBlock Text="自动:" Style="{StaticResource LabelStyle}" Margin="4,0,0,0"/>
                                                <TextBox Text="{Binding AutoSpeed, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource DarkTextBox}" Width="55"
                                                         LostFocus="AutoSpeed_LostFocus" Tag="{Binding}"/>
                                            </StackPanel>

                                            <!-- 行3: 目标位置 + 绝对运动 + 回原点 -->
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2">
                                                <TextBlock Text="目标:" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding TargetPosition, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource DarkTextBox}" Width="80"/>
                                                <TextBlock Text="mm" Style="{StaticResource LabelStyle}"/>
                                                <Button Content="▷ 绝对运动" Style="{StaticResource AccentButton}"
                                                        Padding="8,3" FontSize="11" Margin="6,0,0,0"
                                                        Click="AbsoluteMove_Click" Tag="{Binding}"/>
                                                <Button Content="⌂ 回零" Style="{StaticResource SmallButton}"
                                                        Click="Home_Click" Tag="{Binding}" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>

                    <!-- 夹爪控制面板 -->
                    <GroupBox Header="🤏 夹爪控制" Style="{StaticResource DarkGroupBox}">
                        <StackPanel>
                            <!-- 操作按钮 -->
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <Button Content="🔓 打开" Style="{StaticResource SuccessButton}"
                                        Command="{Binding ClawOpenCommand}" Padding="12,5" Margin="2,0"/>
                                <Button Content="🔒 关闭" Style="{StaticResource DangerButton}"
                                        Command="{Binding ClawCloseCommand}" Padding="12,5" Margin="2,0"/>
                                <Button Content="🔄 旋转" Style="{StaticResource AccentButton}"
                                        Command="{Binding ClawRotateCommand}" Padding="12,5" Margin="2,0"/>
                            </StackPanel>

                            <!-- 参数 -->
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="打开位:" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ClawOpenPos}"
                                         Style="{StaticResource DarkTextBox}" Margin="2,2"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="关闭位:" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding ClawClosePos}"
                                         Style="{StaticResource DarkTextBox}" Margin="2,2"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="角度:" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ClawAngle}"
                                         Style="{StaticResource DarkTextBox}" Margin="2,2"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="关闭力矩:" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding ClawCloseTorque}"
                                         Style="{StaticResource DarkTextBox}" Margin="2,2"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="打开力矩:" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ClawOpenTorque}"
                                         Style="{StaticResource DarkTextBox}" Margin="2,2"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ========== 底部状态栏 ========== -->
        <Border Grid.Row="2" Background="{StaticResource BgMediumBrush}" Padding="10,5">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding IsPlcConnected, Converter={StaticResource ConnectionStateToBrushConverter}}"
                             Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding IsPlcConnected, Converter={StaticResource ConnectionStateToTextConverter}, ConverterParameter='PLC: '}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,16,0"/>

                    <Ellipse Width="8" Height="8"
                             Fill="{Binding IsDbConnected, Converter={StaticResource ConnectionStateToBrushConverter}}"
                             Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding IsDbConnected, Converter={StaticResource ConnectionStateToTextConverter}, ConverterParameter='DB: '}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,16,0"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="11" DockPanel.Dock="Left" VerticalAlignment="Center"/>

                <TextBlock x:Name="tbClock" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
