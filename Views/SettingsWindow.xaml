<Window x:Class="PointPositionApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统设置" Height="520" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 数据库设置 -->
                <GroupBox Header="💾 数据库" Style="{StaticResource DarkGroupBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="数据库路径:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                        <TextBox x:Name="tbDbPath" Style="{StaticResource DarkTextBox}" Grid.Column="1"/>
                    </Grid>
                </GroupBox>

                <!-- PLC设置 -->
                <GroupBox Header="🔌 PLC 通信" Style="{StaticResource DarkGroupBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="IP 地址:" Style="{StaticResource LabelStyle}" Grid.Row="0" Grid.Column="0"/>
                        <TextBox x:Name="tbPlcIp" Style="{StaticResource DarkTextBox}" Grid.Row="0" Grid.Column="1" Margin="0,2"/>

                        <TextBlock Text="端口:" Style="{StaticResource LabelStyle}" Grid.Row="1" Grid.Column="0"/>
                        <TextBox x:Name="tbPlcPort" Style="{StaticResource DarkTextBox}" Grid.Row="1" Grid.Column="1" Margin="0,2"/>

                        <TextBlock Text="轮询周期(ms):" Style="{StaticResource LabelStyle}" Grid.Row="2" Grid.Column="0"/>
                        <TextBox x:Name="tbPollInterval" Style="{StaticResource DarkTextBox}" Grid.Row="2" Grid.Column="1" Margin="0,2"/>
                    </Grid>
                </GroupBox>

                <!-- 日志设置 -->
                <GroupBox Header="📝 日志" Style="{StaticResource DarkGroupBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="日志级别:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                        <ComboBox x:Name="cbLogLevel" Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                  Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource TextPrimaryBrush}">
                            <ComboBoxItem Content="Debug"/>
                            <ComboBoxItem Content="Info"/>
                            <ComboBoxItem Content="Warn"/>
                            <ComboBoxItem Content="Error"/>
                        </ComboBox>
                    </Grid>
                </GroupBox>

                <!-- Modbus地址映射（只读展示） -->
                <GroupBox Header="📋 轴地址映射（只读，修改请编辑 appsettings.json）" Style="{StaticResource DarkGroupBox}">
                    <TextBox x:Name="tbAxisMapping" Style="{StaticResource DarkTextBox}"
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             MaxHeight="160" VerticalScrollBarVisibility="Auto"
                             FontSize="10" FontFamily="Consolas"/>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="✔ 保存" Style="{StaticResource SuccessButton}" Width="90"
                    Click="BtnSave_Click" Margin="4,0"/>
            <Button Content="✘ 取消" Style="{StaticResource DangerButton}" Width="90"
                    Click="BtnCancel_Click" Margin="4,0"/>
        </StackPanel>
    </Grid>
</Window>
